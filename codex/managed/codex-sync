#!/usr/bin/env bash
set -euo pipefail

script_source="${BASH_SOURCE[0]}"
while [[ -L "$script_source" ]]; do
  script_dir="$(cd "$(dirname "$script_source")" && pwd)"
  script_source="$(readlink "$script_source")"
  [[ "$script_source" == /* ]] || script_source="$script_dir/$script_source"
done
managed_root="$(cd "$(dirname "$script_source")" && pwd)"
codex_home="${CODEX_HOME:-$HOME/.codex}"
penpot_compose_file="$managed_root/../../docker/penpot-mcp/compose.yaml"

usage() {
  cat <<'EOF'
Usage: codex-sync COMMAND [--dry-run]

Commands:
  install  Install/reconcile config, Codex, skills, plugins, and MCPs
  apply    Render and install config.toml and AGENTS.md for this machine
  update   Apply configuration, update Codex, skills, and Ponytail
  doctor   Validate rendered configuration and inspect the active installation

Set CODEX_MANAGED_MACHINE for non-interactive use. If unset in a terminal,
codex-sync asks which machine it is running on. Supported values:
  macos-work-laptop | macos-personal-macmini | omarchy-laptop | ubuntu-server
EOF
}

detect_machine() {
  if [[ -n "${CODEX_MANAGED_MACHINE:-}" ]]; then
    printf '%s\n' "$CODEX_MANAGED_MACHINE"
    return
  fi

  if [[ ! -t 0 ]]; then
    echo "CODEX_MANAGED_MACHINE is required in non-interactive use." >&2
    return 1
  fi

  local choice
  local options=(
    macos-work-laptop
    macos-personal-macmini
    omarchy-laptop
    ubuntu-server
  )
  PS3="Select this machine: "
  select choice in "${options[@]}"; do
    if [[ -n "${choice:-}" ]]; then
      printf '%s\n' "$choice"
      return
    fi
    echo "Invalid selection." >&2
  done
  echo "No machine selected." >&2
  return 1
}

profile_for_machine() {
  case "$1" in
    macos-work-laptop) printf '%s\n' work ;;
    macos-personal-macmini|omarchy-laptop|ubuntu-server) printf '%s\n' personal ;;
    *) echo "Unsupported machine: $1" >&2; return 1 ;;
  esac
}

docker_servers_for_profile() {
  local profile="$1" servers="" file server
  for file in \
    "$managed_root/docker-mcp/shared.servers" \
    "$managed_root/docker-mcp/profiles/$profile.servers"; do
    [[ -f "$file" ]] || { echo "Missing Docker MCP server manifest: $file" >&2; return 1; }
    while IFS= read -r server || [[ -n "$server" ]]; do
      [[ -n "$server" && "${server#\#}" == "$server" ]] || continue
      [[ "$server" =~ ^[a-z0-9][a-z0-9-]*$ ]] || {
        echo "Invalid Docker MCP server name in $file: $server" >&2
        return 1
      }
      servers="${servers:+$servers,}$server"
    done < "$file"
  done
  printf '%s\n' "$servers"
}

render_config() {
  local machine="$1" profile="$2" output="$3"
  local docker_servers docker_timeout docker_secrets docker_config
  docker_servers="$(docker_servers_for_profile "$profile")"
  docker_secrets="$HOME/.config/codex/docker-mcp.env"
  docker_config="$HOME/.docker/mcp/codex-managed-config.yaml"
  if [[ "$profile" == work ]]; then
    docker_timeout=300
  else
    docker_timeout=60
  fi
  local fragments=(
    "$managed_root/shared/config.toml"
    "$managed_root/profiles/$profile.toml"
    "$managed_root/machines/$machine.toml"
  )

  {
    printf '# Generated by codex/managed/codex-sync for %s (%s).\n' "$machine" "$profile"
    printf '# Edit the source fragments in the dotfiles repository, not this file.\n'
    local fragment
    for fragment in "${fragments[@]}"; do
      [[ -f "$fragment" ]] || { echo "Missing fragment: $fragment" >&2; return 1; }
      printf '\n# Source: %s\n' "${fragment#$managed_root/}"
      cat "$fragment"
      printf '\n'
    done
    printf '\n# Source: docker-mcp server manifests\n'
    printf '[mcp_servers.MCP_DOCKER]\n'
    printf 'command = "docker"\n'
    printf 'args = ["mcp", "gateway", "run", "--catalog", "docker-official.json", "--config", "%s", "--secrets", "%s", "--servers", "%s"]\n' "$docker_config" "$docker_secrets" "$docker_servers"
    printf 'startup_timeout_sec = %s\n' "$docker_timeout"
  } > "$output"

  "$managed_root/render-managed-hook-trust.py" \
    "$managed_root/dependencies.conf" "$managed_root/../.." >> "$output"

  validate_config "$output"
}

validate_config() {
  local config="$1" validation_home report
  command -v codex >/dev/null 2>&1 || {
    echo "Codex is required to validate the rendered configuration." >&2
    return 1
  }
  validation_home="$(mktemp -d "${TMPDIR:-/tmp}/codex-config-validation-XXXXXX")"
  install -m 0600 -- "$config" "$validation_home/config.toml"
  report="$(CODEX_HOME="$validation_home" codex --strict-config doctor --json 2>&1 || true)"
  case "$(basename "$validation_home")" in
    codex-config-validation-*) rm -rf -- "$validation_home" ;;
    *) echo "Refusing to remove unexpected validation directory: $validation_home" >&2 ;;
  esac
  if ! printf '%s\n' "$report" | grep -Fq '"config.toml parse": "ok"'; then
    echo "Codex rejected the rendered configuration:" >&2
    printf '%s\n' "$report" >&2
    return 1
  fi
}

backup_and_install() {
  local source="$1" target="$2"
  if [[ -f "$target" ]] && ! cmp -s "$source" "$target"; then
    cp -p -- "$target" "$target.backup.$(date -u '+%Y%m%dT%H%M%SZ')"
  fi
  install -m 0600 -- "$source" "$target"
}

purge_removed_integrations() {
  local target
  for target in \
    "$codex_home/plugins/cache/openai-curated-remote/linear" \
    "$codex_home/plugins/cache/openai-curated-remote/obsidian" \
    "$codex_home/.tmp/plugins/plugins/linear" \
    "$codex_home/.tmp/plugins/plugins/obsidian"; do
    [[ -d "$target" ]] || continue
    case "$(basename "$target")" in
      linear|obsidian) find "$target" -depth -delete ;;
      *) echo "Refusing unexpected integration cache path: $target" >&2; return 1 ;;
    esac
  done
}

remove_legacy_skill_installs() {
  local manifest="$managed_root/legacy-skills.conf"
  local agents_home="${AGENTS_HOME:-$HOME/.agents}"
  local skill replacement legacy_path managed_path
  [[ -f "$manifest" ]] || {
    echo "Missing legacy skill manifest: $manifest" >&2
    return 1
  }

  while IFS='|' read -r skill replacement || [[ -n "$skill$replacement" ]]; do
    [[ -n "$skill" && "${skill#\#}" == "$skill" ]] || continue
    [[ "$skill" =~ ^[a-z0-9][a-z0-9-]*$ ]] || {
      echo "Invalid legacy skill name: $skill" >&2
      return 1
    }
    replacement="${replacement:-$skill}"
    [[ "$replacement" =~ ^[a-z0-9][a-z0-9-]*$ ]] || {
      echo "Invalid managed replacement skill name: $replacement" >&2
      return 1
    }
    legacy_path="$codex_home/skills/$skill"
    managed_path="$agents_home/skills/$replacement"
    [[ -e "$legacy_path" || -L "$legacy_path" ]] || continue
    if [[ ! -f "$managed_path/SKILL.md" ]]; then
      echo "Legacy skill remains because managed replacement is missing: $skill -> $replacement" >&2
      return 1
    fi
    if (( dry_run )); then
      echo "would remove legacy Codex skill install: $skill"
      continue
    fi
    case "$legacy_path" in
      "$codex_home"/skills/"$skill") find "$legacy_path" -depth -delete ;;
      *) echo "Refusing unexpected legacy skill path: $legacy_path" >&2; return 1 ;;
    esac
    echo "Removed legacy Codex skill install: $skill"
  done < "$manifest"
}

install_local_docker_files() {
  local profile="$1"
  local secrets_dir="$HOME/.config/codex"
  local secrets_file="$secrets_dir/docker-mcp.env"
  local docker_config="$HOME/.docker/mcp/codex-managed-config.yaml"
  mkdir -p "$secrets_dir"
  if [[ ! -f "$secrets_file" ]]; then
    install -m 0600 -- "$managed_root/docker-mcp/secrets.env.example" "$secrets_file"
    echo "Created local Docker MCP secrets file: $secrets_file"
  fi

  mkdir -p "$(dirname "$docker_config")"
  if [[ "$profile" != work ]]; then
    if [[ ! -f "$docker_config" ]]; then
      printf '{}\n' > "$docker_config"
      chmod 0600 "$docker_config"
      echo "Created local Docker MCP configuration: $docker_config"
    fi
    return 0
  fi
  if [[ -f "$docker_config" ]] && rg -q '^[[:space:]]+jira:' "$docker_config" && \
    [[ -z "${CODEX_JIRA_URL:-}" && -z "${CODEX_JIRA_USERNAME:-}" ]]; then
    echo "Keeping existing work Docker MCP configuration: $docker_config"
    return 0
  fi
  if [[ -z "${CODEX_JIRA_URL:-}" || -z "${CODEX_JIRA_USERNAME:-}" ]]; then
    echo "Work setup requires CODEX_JIRA_URL and CODEX_JIRA_USERNAME before apply can configure Atlassian." >&2
    return 1
  fi
  local value safe_value_pattern='^[A-Za-z0-9@._:/?&=%+-]+$'
  for value in "$CODEX_JIRA_URL" "$CODEX_JIRA_USERNAME" "${CODEX_CONFLUENCE_URL:-}" "${CODEX_CONFLUENCE_USERNAME:-}"; do
    [[ -z "$value" || "$value" =~ $safe_value_pattern ]] || {
      echo "Unsupported character in work Atlassian configuration." >&2
      return 1
    }
  done
  local rendered_config
  rendered_config="$(mktemp "${TMPDIR:-/tmp}/docker-mcp-config.yaml-XXXXXX")"
  {
    echo "atlassian:"
    echo "  jira:"
    printf '    url: "%s"\n' "$CODEX_JIRA_URL"
    printf '    username: "%s"\n' "$CODEX_JIRA_USERNAME"
    if [[ -n "${CODEX_CONFLUENCE_URL:-}" && -n "${CODEX_CONFLUENCE_USERNAME:-}" ]]; then
      echo "  confluence:"
      printf '    url: "%s"\n' "$CODEX_CONFLUENCE_URL"
      printf '    username: "%s"\n' "$CODEX_CONFLUENCE_USERNAME"
    fi
  } > "$rendered_config"
  backup_and_install "$rendered_config" "$docker_config"
  rm -f -- "$rendered_config"
  echo "Configured Atlassian Docker MCP settings: $docker_config"
}

run_or_print() {
  if (( dry_run )); then
    printf 'would run:'
    printf ' %q' "$@"
    printf '\n'
  else
    "$@" </dev/null
  fi
}

update_codex() {
  if (( dry_run )); then
    echo "would compare the installed Codex version with npm and install @openai/codex@latest only when outdated"
  else
    local current_version latest_version
    current_version="$(codex --version)"
    current_version="${current_version##* }"
    latest_version="$(npm view @openai/codex version --silent)"
    if [[ "$current_version" != "$latest_version" ]]; then
      npm install -g --loglevel=error @openai/codex@latest
    fi
  fi
}

apply_config() {
  local machine="$1" profile="$2"
  local rendered
  rendered="$(mktemp "${TMPDIR:-/tmp}/codex-config-rendered.toml-XXXXXX")"
  trap 'rm -f -- "$rendered"' RETURN
  render_config "$machine" "$profile" "$rendered"

  if (( dry_run )); then
    cat "$rendered"
    return
  fi

  mkdir -p -- "$codex_home"
  install_local_docker_files "$profile"
  backup_and_install "$rendered" "$codex_home/config.toml"
  backup_and_install "$managed_root/shared/AGENTS.md" "$codex_home/AGENTS.md"
  purge_removed_integrations
  echo "Applied Codex configuration for $machine ($profile)."
}

update_dependencies() {
  while IFS='|' read -r kind source selection; do
    [[ -n "$kind" && "${kind#\#}" == "$kind" ]] || continue
    case "$kind" in
      skill-repo-except)
        install_skill_repo_except "$source" "$selection"
        ;;
      skill)
        IFS=',' read -r -a skills <<< "$selection"
        run_or_print npx skills add "$source" -g -a codex -s "${skills[@]}" -y
        ;;
      npm-global)
        run_or_print npm install -g "$source"
        ;;
      plugin-marketplace)
        run_or_print codex plugin marketplace upgrade "$source"
        ;;
      plugin)
        run_or_print codex plugin add "$source"
        ;;
      *) echo "Unknown dependency kind: $kind" >&2; return 1 ;;
    esac
  done < "$managed_root/dependencies.conf"
}

reset_managed_dependencies() {
  if (( dry_run )); then
    echo "would remove all global Codex skills before installing the declared set"
    echo "would remove undeclared Codex plugins"
    echo "would remove undeclared Codex plugin marketplaces"
    return
  fi

  npx skills remove --skill '*' -g -a codex -y

  local plugin status rest
  while read -r plugin status rest; do
    [[ "$status" == "installed," ]] || continue
    grep -Fq "plugin|$plugin|" "$managed_root/dependencies.conf" || \
      codex plugin remove "$plugin"
  done < <(codex plugin list)

  local marketplace root
  while read -r marketplace root; do
    [[ "$marketplace" != "MARKETPLACE" && "$marketplace" != "openai-curated" ]] || continue
    grep -Fq "plugin-marketplace|$marketplace|" "$managed_root/dependencies.conf" || \
      codex plugin marketplace remove "$marketplace"
  done < <(codex plugin marketplace list)
}

install_skill_repo_except() {
  local source="$1" exclusions="$2"
  [[ "$source" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]] || {
    echo "Invalid GitHub skill repository: $source" >&2
    return 1
  }

  if (( dry_run )); then
    echo "would install every current skill from $source except ${exclusions//,/ }"
    return 0
  fi

  local required
  for required in git python3; do
    command -v "$required" >/dev/null 2>&1 || {
      echo "Cannot reconcile the $source skill suite without $required." >&2
      return 1
    }
  done

  local checkout skill_file skill_name
  local -a selected_skills=()
  checkout="$(mktemp -d "${TMPDIR:-/tmp}/codex-skill-repo-XXXXXX")"
  if ! git clone --depth 1 "https://github.com/$source.git" "$checkout"; then
    find "$checkout" -depth -delete
    return 1
  fi

  while IFS= read -r skill_file; do
    skill_name="$(basename "$(dirname "$skill_file")")"
    case ",$exclusions," in
      *",$skill_name,"*) continue ;;
    esac
    selected_skills+=("$skill_name")
  done < <(find "$checkout" -type f -name SKILL.md -print | sort)

  if (( ${#selected_skills[@]} == 0 )); then
    echo "No installable skills found in $source." >&2
    find "$checkout" -depth -delete
    return 1
  fi

  if ! npx skills add "$source" -g -a codex -s "${selected_skills[@]}" -y; then
    find "$checkout" -depth -delete
    return 1
  fi

  local skill_lock="${AGENTS_HOME:-$HOME/.agents}/.skill-lock.json"
  local stale_skill
  if [[ -f "$skill_lock" ]]; then
    if ! python3 "$managed_root/reconcile-skill-lock.py" \
      "$skill_lock" "$source" "${selected_skills[@]}" \
      > "$checkout/stale-skills.txt"; then
      find "$checkout" -depth -delete
      return 1
    fi
    while IFS= read -r stale_skill; do
      [[ -n "$stale_skill" ]] || continue
      npx skills remove "$stale_skill" -g -a codex -y
    done < "$checkout/stale-skills.txt"
  fi
  find "$checkout" -depth -delete
}

update_docker_mcp() {
  local profile="$1"
  local required
  for required in docker curl python3; do
    command -v "$required" >/dev/null 2>&1 || {
      echo "Cannot update Docker MCP Gateway without: $required" >&2
      return 1
    }
  done
  if [[ "$(uname -s)" == Darwin ]]; then
    if docker mcp version >/dev/null 2>&1; then
      echo "Docker Desktop manages the Docker MCP Gateway plugin on macOS."
    else
      echo "Enable MCP Toolkit in Docker Desktop 4.59 or later." >&2
      return 1
    fi
  else
    for required in git go make; do
      command -v "$required" >/dev/null 2>&1 || {
        echo "Cannot update Docker MCP Gateway without: $required" >&2
        return 1
      }
    done

    if (( dry_run )); then
      echo "would install the latest tagged docker/mcp-gateway release under ~/.docker/cli-plugins"
    else
      local repository="https://github.com/docker/mcp-gateway.git"
      local latest_tag build_dir staged_plugin target_plugin temporary_plugin
      latest_tag="$(git ls-remote --refs --tags "$repository" | awk -F/ '{print $3}' | sort -V | tail -1)"
      [[ -n "$latest_tag" ]] || { echo "Unable to resolve a Docker MCP Gateway release." >&2; return 1; }
      build_dir="$(mktemp -d "${TMPDIR:-/tmp}/docker-mcp-gateway-build-XXXXXX")"
      staged_plugin="$build_dir/docker-mcp.new"
      target_plugin="$HOME/.docker/cli-plugins/docker-mcp"
      temporary_plugin="$target_plugin.new"
      if ! {
        git clone --depth 1 --branch "$latest_tag" "$repository" "$build_dir" &&
          mkdir -p "$HOME/.docker/cli-plugins" &&
          make -C "$build_dir" docker-mcp DEV_VERSION="$latest_tag" DOCKER_MCP_CLI_PLUGIN_DST="$staged_plugin" &&
          "$staged_plugin" version &&
          install -m 0755 -- "$staged_plugin" "$temporary_plugin" &&
          "$temporary_plugin" version &&
          mv -f -- "$temporary_plugin" "$target_plugin" &&
          docker mcp version
      }; then
        rm -f -- "$temporary_plugin"
        case "$(basename "$build_dir")" in
          docker-mcp-gateway-build-*) rm -rf -- "$build_dir" ;;
        esac
        return 1
      fi
      case "$(basename "$build_dir")" in
        docker-mcp-gateway-build-*) rm -rf -- "$build_dir" ;;
        *) echo "Refusing to remove unexpected build directory: $build_dir" >&2 ;;
      esac
    fi
  fi

  if (( dry_run )); then
    echo "would refresh Docker's curated MCP catalogue as docker-official.json"
  else
    local catalog_dir="$HOME/.docker/mcp/catalogs"
    local catalog="$catalog_dir/docker-official.json"
    mkdir -p "$catalog_dir"
    curl -fsSL https://desktop.docker.com/mcp/catalog/v3/catalog.json -o "$catalog.tmp"
    local selected_servers
    selected_servers="$(docker_servers_for_profile "$profile")"
    if ! python3 - "$catalog.tmp" "$selected_servers" <<'PY'
import json
import pathlib
import sys

catalog = json.loads(pathlib.Path(sys.argv[1]).read_text())
selected = set(sys.argv[2].split(","))
registry = catalog.get("registry", {})
for removed_server in ("linear", "obsidian"):
    registry.pop(removed_server, None)
pathlib.Path(sys.argv[1]).write_text(json.dumps(catalog, indent=2, ensure_ascii=False) + "\n")
available = set(registry)
missing = sorted(selected - available)
if missing:
    raise SystemExit("Docker MCP servers missing from curated catalogue: " + ", ".join(missing))
PY
    then
      rm -f -- "$catalog.tmp"
      return 1
    fi
    mv -- "$catalog.tmp" "$catalog"
    echo "Refreshed Docker's curated MCP catalogue: $catalog"
  fi
}

update_machine_services() {
  local machine="$1"
  [[ "$machine" == ubuntu-server ]] || return 0

  [[ -f "$penpot_compose_file" ]] || {
    echo "Missing Penpot MCP Compose definition: $penpot_compose_file" >&2
    return 1
  }

  local penpot_version
  if (( dry_run )); then
    penpot_version=stable
  else
    penpot_version="$(npm view @penpot/mcp@stable version 2>/dev/null)"
    [[ -n "$penpot_version" ]] || {
      echo "Unable to resolve @penpot/mcp@stable." >&2
      return 1
    }
  fi

  run_or_print env "PENPOT_MCP_VERSION=$penpot_version" \
    docker compose -f "$penpot_compose_file" build --pull
  run_or_print env "PENPOT_MCP_VERSION=$penpot_version" \
    docker compose -f "$penpot_compose_file" up -d --remove-orphans
}

doctor_machine_services() {
  local machine="$1"
  [[ "$machine" == ubuntu-server ]] || return 0

  local failed=0
  if docker compose -f "$penpot_compose_file" ps --status running --services 2>/dev/null | \
    grep -Fxq penpot-mcp; then
    echo "found: Penpot MCP Docker service"
  else
    echo "missing: running Penpot MCP Docker service"
    failed=1
  fi
  if curl -fsS --max-time 5 http://nuc:4400/manifest.json >/dev/null; then
    echo "passed: Penpot plugin manifest endpoint"
  else
    echo "failed: Penpot plugin manifest endpoint"
    failed=1
  fi
  if curl -fsS --max-time 5 http://nuc:4400/index.js | grep -Fq 'ws://nuc:4402'; then
    echo "passed: Penpot plugin WebSocket address"
  else
    echo "failed: Penpot plugin WebSocket address"
    failed=1
  fi
  if curl -fsS --max-time 5 \
    -X POST http://127.0.0.1:4401/mcp \
    -H 'Content-Type: application/json' \
    -H 'Accept: application/json, text/event-stream' \
    -H 'MCP-Protocol-Version: 2025-03-26' \
    --data '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-03-26","capabilities":{},"clientInfo":{"name":"codex-sync-doctor","version":"1"}}}' | \
    grep -Fq '"serverInfo"'; then
    echo "passed: Penpot MCP HTTP endpoint"
  else
    echo "failed: Penpot MCP HTTP endpoint"
    failed=1
  fi
  return "$failed"
}

doctor() {
  local machine="$1" profile="$2" rendered
  local failures=0
  rendered="$(mktemp "${TMPDIR:-/tmp}/codex-config-doctor.toml-XXXXXX")"
  trap 'rm -f -- "$rendered"' RETURN
  render_config "$machine" "$profile" "$rendered"
  echo "Rendered configuration is valid TOML for $machine ($profile)."

  local command
  for command in codex codegraph npm npx python3; do
    if command -v "$command" >/dev/null 2>&1; then
      printf 'found: %s (%s)\n' "$command" "$(command -v "$command")"
    else
      printf 'missing: %s\n' "$command"
      failures=1
    fi
  done

  if command -v docker >/dev/null 2>&1; then
    echo "found: docker ($(command -v docker))"
    if docker mcp version >/dev/null 2>&1; then
      echo "found: Docker MCP Gateway CLI plugin"
      if [[ -f "$HOME/.docker/mcp/catalogs/docker-official.json" ]]; then
        echo "found: Docker curated MCP catalogue"
      else
        echo "missing: run codex-sync update to install Docker's curated MCP catalogue"
        failures=1
      fi
    elif [[ "$(uname -s)" == Darwin ]]; then
      echo "missing: enable MCP Toolkit in Docker Desktop 4.59 or later"
      failures=1
    else
      echo "missing: install the Docker MCP Gateway CLI plugin under ~/.docker/cli-plugins"
      failures=1
    fi
  else
    echo "missing: docker is not installed"
    failures=1
  fi

  local secrets_file="$HOME/.config/codex/docker-mcp.env"
  if [[ -f "$secrets_file" ]]; then
    echo "found: local Docker MCP secrets file"
  else
    echo "missing: $secrets_file"
    failures=1
  fi

  local docker_config="$HOME/.docker/mcp/codex-managed-config.yaml"
  if [[ ! -f "$docker_config" ]]; then
    echo "missing: $docker_config"
    failures=1
  elif [[ "$profile" == work ]] && ! rg -q '^[[:space:]]+jira:' "$docker_config"; then
    echo "missing: work Jira configuration in $docker_config"
    failures=1
  fi

  if docker mcp version >/dev/null 2>&1 && [[ -f "$HOME/.docker/mcp/catalogs/docker-official.json" ]]; then
    local selected_servers gateway_output
    selected_servers="$(docker_servers_for_profile "$profile")"
    if gateway_output="$(docker mcp gateway run --dry-run \
      --catalog docker-official.json --config "$docker_config" --secrets "$secrets_file" \
      --servers "$selected_servers" 2>&1)" && \
      printf '%s\n' "$gateway_output" | grep -Eq '[1-9][0-9]* tools listed'; then
      echo "passed: Docker MCP Gateway dry run"
    else
      echo "failed: Docker MCP Gateway dry run"
      printf '%s\n' "$gateway_output" >&2
      failures=1
    fi
  fi

  if ! npx skills list --global --json >/dev/null 2>&1; then
    echo "failed: global skill inventory"
    failures=1
  else
    echo "passed: global skill inventory"
  fi

  local plugin_list
  plugin_list="$(codex plugin list 2>&1 || true)"
  if printf '%s\n' "$plugin_list" | grep -Eq '^[[:space:]]*ponytail@ponytail[[:space:]]+installed, enabled'; then
    echo "found: ponytail plugin"
  else
    echo "missing: ponytail plugin"
    failures=1
  fi
  if printf '%s\n' "$plugin_list" | grep -Eq '^[[:space:]]*github@openai-curated[[:space:]]+installed, enabled'; then
    echo "found: github plugin"
  else
    echo "missing: github plugin"
    failures=1
  fi

  if [[ -f "$codex_home/config.toml" ]]; then
    codex doctor --summary --no-color || failures=1
  else
    echo "Codex configuration is not installed at $codex_home/config.toml."
    failures=1
  fi
  doctor_machine_services "$machine" || failures=1
  remove_legacy_skill_installs || failures=1
  purge_removed_integrations || failures=1
  return "$failures"
}

command_name="${1:-}"
[[ -n "$command_name" ]] || { usage >&2; exit 2; }
shift

dry_run=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) dry_run=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

machine="$(detect_machine)"
profile="$(profile_for_machine "$machine")"

case "$command_name" in
  apply) apply_config "$machine" "$profile" ;;
  install|update)
    update_codex
    if (( dry_run )); then
      echo "would apply Codex configuration for $machine ($profile)"
    else
      apply_config "$machine" "$profile"
    fi
    update_docker_mcp "$profile"
    update_machine_services "$machine"
    reset_managed_dependencies
    update_dependencies
    remove_legacy_skill_installs
    if (( ! dry_run )); then
      purge_removed_integrations
      apply_config "$machine" "$profile"
    fi
    ;;
  doctor) doctor "$machine" "$profile" ;;
  -h|--help) usage ;;
  *) echo "Unknown command: $command_name" >&2; usage >&2; exit 2 ;;
esac
